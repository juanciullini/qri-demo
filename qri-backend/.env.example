# Database
DATABASE_URL=postgresql://qri:qri@localhost:5432/qri

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-min-32-chars-long-secret-key
JWT_REFRESH_SECRET=change-me-another-32-chars-long-key

# Server
PORT=3000
NODE_ENV=development

# COELSA
COELSA_MODE=sandbox
COELSA_BASE_URL=https://homodebin-03.coelsa.com.ar
COELSA_AUTH_URL=https://homoauth.coelsa.com.ar/auth
COELSA_CVU_URL=https://homocvu-03.coelsa.com.ar
COELSA_CERT_PATH=./certs/client.pem
COELSA_KEY_PATH=./certs/client.key
COELSA_CA_PATH=./certs/coelsa-ca.pem
COELSA_DEBIN_USERNAME=
COELSA_DEBIN_PASSWORD=
COELSA_DEBIN_ID=
COELSA_DEBIN_SECRET=
COELSA_CVU_USERNAME=
COELSA_CVU_PASSWORD=
COELSA_CVU_ID=
COELSA_CVU_SECRET=

# PSP
PSP_CUIT=30000000001
PSP_REVERSE_DOMAIN=app.qri

# Encryption
ENCRYPTION_KEY=change-me-32-chars-aes256-key!!!

# Frontend
FRONTEND_URL=http://localhost:5173

# Sandbox
SANDBOX_DEFAULT_SCENARIO=happy_path
SANDBOX_DELAY_MS=0
